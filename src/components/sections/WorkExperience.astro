---
import FalschParkerSVG from "../../assets/falschparker.svg";
import TrueZKSVG from "../../assets/truezk.svg";
import HealthBarosaSVG from "../../assets/healthbarosa.svg";
import AuxesiaSVG from "../../assets/auxesia.svg";
import StagerAnimation from "../StagerAnimation.astro";
---

<StagerAnimation isIndividualTitle staggerOrder={6}>
  <div class="flex flex-col gap-10">
    <div class="text-middle">Work Experience</div>
    <div class="text-middle items-center gap-10 text-sm font-light md:flex">
      <div class="w-32">Sep '24 - Present</div>
      <div class="flex items-center">
        Sr Full-stack Dev at{" "}
        <span>
          <FalschParkerSVG />
        </span>{" "}
        Falsch Parker
      </div>
    </div>
    <div class="text-middle gap-10 text-sm font-light md:flex">
      <div class="w-32">June '23 - Sep '24</div>
      <div class="flex items-center">
        Founding Full-stack Dev at{" "}
        <span>
          <TrueZKSVG />
        </span>{" "}
        TrueZK
      </div>
    </div>
    <div class="text-middle gap-10 text-sm font-light md:flex">
      <div class="w-32">Mar - May '23</div>
      <div class="flex items-center">
        Frontend Devloper Intern at{" "}
        <span class="mx-1">
          <HealthBarosaSVG />
        </span>{" "}
        HealthBarosa
      </div>
    </div>
    <div class="text-middle gap-10 text-sm font-light md:flex">
      <div class="w-32">May '22 - Feb '23</div>
      <div class="flex items-center">
        Frontend Devloper Intern at{" "}
        <span class="mx-1">
          <AuxesiaSVG />
        </span>{" "}
        Auxesia
      </div>
    </div>
  </div>
</StagerAnimation>
