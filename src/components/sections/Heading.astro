---
import { Picture } from "astro:assets";
import sawanImg from "../../assets/raster/sawan.png";
import falschParkerImg from "../../assets/raster/falschparker.png";
import mapImg from "../../assets/raster/map.png";
import { HEADING_DETAILS } from "../../constants/heading";

const { city, country, currentCompany, name } = HEADING_DETAILS;
---

<h1 class="flex flex-col pt-20 font-serif text-2xl antialiased md:text-4xl">
  <div
    class="animate-enter animate-enter-individual-title flex items-center gap-2"
    style={{ "--stagger": 1 }}
  >
    <span class="text-light">Hey,</span>
    <span class="text-dark">I’m</span>
    <Picture
      loading={"eager"}
      src={sawanImg}
      formats={["avif", "webp", "png"]}
      alt="sawan"
      draggable={false}
      class="w-10 md:w-20"
    />
    <span class="text-dark">{name}</span>
  </div>
  <div
    class="animate-enter animate-enter-individual-title flex items-center gap-2 md:-translate-y-4"
    style={{ "--stagger": 2 }}
  >
    <span
      class="bg-linear-to-r from-violet-500 to-blue-500 bg-clip-text text-transparent"
    >
      a Developer
    </span>
    <span class="text-light">at</span>
    <Picture
      loading={"eager"}
      src={falschParkerImg}
      formats={["avif", "webp", "png"]}
      alt="Falsch Parker's Logo"
      draggable={false}
      class="aspect-square w-10 -translate-x-2 md:w-24"
    />
    <span class="text-dark -translate-x-4">{currentCompany}</span>
  </div>
  <div
    class="animate-enter animate-enter-individual-title flex items-center gap-2 md:-translate-y-8"
    style={{ "--stagger": 3 }}
  >
    <span class="text-light">based in</span>
    <span class="text-dark">{city},</span>
    <Picture
      loading={"eager"}
      src={mapImg}
      formats={["avif", "webp", "png"]}
      alt="Kolkata's Map"
      draggable={false}
      class="w-10 -translate-x-2 translate-y-3 md:w-24"
    />

    <span class="text-dark -translate-x-4">{country}</span>
  </div>
</h1>

<style>
  @keyframes enter {
    from {
      transform: translateY(8px);
      filter: blur(5px);
      opacity: 0;
    }
  }

  .animate-enter {
    will-change: transform, opacity;
    animation: enter 800ms cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
    animation-delay: calc(var(--delay, 0ms) * var(--stagger, 0));
  }

  .animate-enter-individual-title {
    --delay: 100ms;
  }
</style>

<script>
  function triggerAnimations() {
    document
      .querySelectorAll<HTMLElement>('[style*="--stagger"]')
      .forEach((el) => {
        el.style.animation = "none";
        el.offsetHeight;
        el.style.animation = "";
        el.classList.add("animate-enter");
      });
  }

  document.addEventListener("DOMContentLoaded", triggerAnimations);
  window.addEventListener("pageshow", (e) => {
    if (e.persisted) triggerAnimations();
  });
</script>
