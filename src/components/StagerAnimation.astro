---
interface Props {
  staggerOrder?: number;
  isIndividualTitle?: boolean;
}

const { staggerOrder, isIndividualTitle } = Astro.props;
---

<div
  class={`animate-enter ${isIndividualTitle ? `animate-enter-individual-title` : ``}`}
  style={{ "--stagger": staggerOrder ?? 0 }}
>
  <slot />
</div>

<style>
  @keyframes enter {
    from {
      transform: translateY(8px);
      filter: blur(5px);
      opacity: 0;
    }
  }

  .animate-enter {
    will-change: transform, opacity;
    animation: enter 800ms cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
    animation-delay: calc(var(--delay, 0ms) * var(--stagger, 0));
  }

  .animate-enter-individual-title {
    --delay: 100ms;
  }
</style>

<script>
  function triggerAnimations() {
    document
      .querySelectorAll<HTMLElement>('[style*="--stagger"]')
      .forEach((el) => {
        el.style.animation = "none";
        el.offsetHeight;
        el.style.animation = "";
        el.classList.add("animate-enter");
      });
  }

  document.addEventListener("DOMContentLoaded", triggerAnimations);
  window.addEventListener("pageshow", (e) => {
    if (e.persisted) triggerAnimations();
  });
</script>
